import turtle
import random
bob = turtle.Turtle()
bob.speed(10000000000000000000000000000000000000000000000000000)
bob.colormode(255)#colormode
r=random.randint(0,255)#R
g=random.randint(0,255)#G
b=0#b
bob.speed(0)
for i in range(36):#LOOP
  sidelength=30#SIDELENGTH
  bob.color(r,g,b)
  b+=20
  for i in range(15):
    for i in range(4):
      bob.forward(sidelength)
      bob.right(90)
    sidelength += 20
  bob.right(10)
