import turtle
import random
bob=turtle.Turtle()
bob.colormode(255)
bob.speed(100000000000000000000000000)
r=random.randint(0,255)
g=random.randint(0,255)
b=random.randint(0,255)
bob.color(r,g,b)
for i in range(6):
  bob.goto(0,0)
  for i in range(10):
    bob.forward(10)
    bob.right(45)
    bob.forward(15)
    bob.backward(15)
    bob.left(90)
    bob.forward(15)
    bob.backward(15)
    bob.right(45)
  bob.left(60)
