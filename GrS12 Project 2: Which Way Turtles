import turtle
import random
turtles=[]
for i in range(10):
 bob=turtle.Turtle()
 bob.colormode(255)
 bob.shape("turtle")
 turtles.append(bob)
for turtle in turtles:
  turtle.color(random.randint(0,255),random.randint(0,255),random.randint(0,255))
  turtle.right(random.randint(0,360))
  turtle.forward(200)
